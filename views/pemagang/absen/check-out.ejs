<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body {
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background: #f8fafc;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 1000px;
            margin: 100px auto 50px;
            padding: 0 20px;
        }

        .location-info {
            background: linear-gradient(135deg, #fff5f5 0%, #fee2e2 100%);
            border: 3px solid #3b82f6;
            border-radius: 16px;
            padding: 20px 30px;
            margin-bottom: 30px;
        }

        .location-row {
            margin-bottom: 10px;
            font-size: 16px;
            color: #E31937;
            font-weight: 600;
        }

        .location-row:last-child {
            margin-bottom: 0;
        }

        .location-label {
            font-weight: 700;
        }

        .form-container {
            background: #e5e7eb;
            border-radius: 16px;
            padding: 40px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #1a1a1a;
            font-size: 14px;
        }

        .form-control {
            width: 100%;
            padding: 14px 18px;
            border: 1px solid #d1d5db;
            border-radius: 10px;
            font-size: 15px;
            background: white;
            box-sizing: border-box;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

        .btn-submit {
            width: auto;
            background: #E31937;
            color: white;
            border: none;
            padding: 14px 24px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            white-space: nowrap;
        }

        .btn-submit:hover {
            background: #be123c;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(227, 25, 55, 0.4);
        }

        .btn-submit:disabled {
            background: #9ca3af;
            cursor: not-allowed;
            transform: none;
        }

        .loading-location {
            color: #3b82f6;
            font-style: italic;
        }

        @media (max-width: 768px) {
            .container {
                margin-top: 80px;
            }

            .form-container {
                padding: 25px;
            }
        }
    </style>
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar scrolled" id="navbar">
        <div class="navbar-logo">
            <a href="/">
                <img src="/img/logotelkom.png" alt="Infranexia Logo">
            </a>
        </div>
        <div class="navbar-menu">
            <a href="/">Home</a>
            <a href="/program">Program</a>
            <a href="/#persyaratan">Persyaratan</a>
            <a href="/pendaftaran">Pendaftaran</a>
            <a href="/faq">FAQ</a>
        </div>
        <% if (locals.user) { %>
            <div class="user-menu">
                <div class="user-menu-trigger">
                    <div class="user-name-pill">
                        <span>Halo, <%= user.nama_depan %></span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
                            stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                    <img src="<%= user.foto_profil ? user.foto_profil : 'https://ui-avatars.com/api/?name=' + user.nama_depan + '+' + (user.nama_belakang || '') + '&size=40&background=E31937&color=fff&bold=true' %>"
                        alt="Profile" class="user-avatar">
                </div>
                <div class="dropdown-menu">
                    <a href="/profil" class="dropdown-item">Profil Saya</a>
                    <% if (locals.pendaftaranStatus==='diterima' ) { %>
                        <div class="dropdown-divider"></div>
                        <a href="/pemagang/absen" class="dropdown-item">Absensi</a>
                        <a href="/pemagang/logbook" class="dropdown-item">Logbook</a>
                        <% } %>
                            <div class="dropdown-divider"></div>
                            <a href="/auth/logout" class="dropdown-item logout">Logout</a>
                </div>
            </div>
            <% } %>
    </nav>

    <div class="container">
        <!-- Location Info Box -->
        <div class="location-info">
            <div class="location-row">
                <span class="location-label">Lokasi Anda :</span>
                <span id="locationText" class="loading-location">Mengambil lokasi...</span>
            </div>
            <div class="location-row">
                <span class="location-label">Waktu :</span>
                <span id="dateTime"></span>
            </div>
        </div>

        <!-- Check-out Form -->
        <div class="form-container">
            <form id="checkOutForm">
                <div class="form-group">
                    <input type="text" class="form-control" id="namaLengkap"
                        value="<%= user.nama_depan %> <%= user.nama_belakang || '' %>" placeholder="Nama Lengkap"
                        readonly>
                </div>

                <div class="form-group">
                    <input type="text" class="form-control" id="perguruan" value="<%= user.institusi || '' %>"
                        placeholder="Perguruan Tinggi" readonly>
                </div>

                <div class="form-group">
                    <label for="divisi">Divisi</label>
                    <input type="text" class="form-control" id="divisi" value="<%= absensi.divisi || '-' %>" readonly>
                </div>

                <div class="form-group">
                    <label for="status">Status</label>
                    <input type="text" class="form-control" id="status" value="Hadir" readonly>
                </div>

                <div
                    style="display: grid; grid-template-columns: 1fr 1fr auto; gap: 20px; align-items: end; margin-bottom: 25px;">
                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="waktuDatang">Waktu Datang</label>
                        <input type="text" class="form-control" id="waktuDatang" readonly
                            value="<%= absensi.jam_datang || '00:00:00' %>"
                            style="color: #6b7280; font-weight: 600; font-size: 16px; text-align: center;">
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="waktuPulang">Waktu Pulang</label>
                        <input type="text" class="form-control" id="waktuPulang" readonly value="00:00:00"
                            style="color: #1a1a1a; font-weight: 600; font-size: 16px; text-align: center;">
                    </div>

                    <button type="button" class="btn-submit" id="btnAbsenPulang" onclick="recordClockOut()">
                        Absen Pulang
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        let userLocation = null;
        let locationAddress = null;

        // Get user location and convert to address
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
                async (position) => {
                    userLocation = {
                        latitude: position.coords.latitude,
                        longitude: position.coords.longitude
                    };

                    // Use reverse geocoding to get address
                    try {
                        const response = await fetch(
                            `https://nominatim.openstreetmap.org/reverse?format=json&lat=${userLocation.latitude}&lon=${userLocation.longitude}&zoom=18&addressdetails=1`,
                            {
                                headers: {
                                    'Accept-Language': 'id'
                                }
                            }
                        );
                        const data = await response.json();

                        // Build address with short place name + general location
                        const addr = data.address;
                        let addressParts = [];

                        // Add short place name if available
                        if (data.name) addressParts.push(data.name);

                        // Add road name
                        if (addr.road) addressParts.push(addr.road);

                        // Add general area
                        if (addr.suburb || addr.neighbourhood || addr.village) {
                            addressParts.push(addr.suburb || addr.neighbourhood || addr.village);
                        }

                        if (addr.city || addr.town || addr.municipality) {
                            addressParts.push(addr.city || addr.town || addr.municipality);
                        }

                        locationAddress = addressParts.join(', ') || data.display_name;

                        document.getElementById('locationText').textContent = locationAddress;
                        document.getElementById('locationText').classList.remove('loading-location');
                    } catch (error) {
                        console.error('Reverse geocoding error:', error);
                        document.getElementById('locationText').textContent =
                            `${position.coords.latitude.toFixed(6)}, ${position.coords.longitude.toFixed(6)}`;
                        document.getElementById('locationText').classList.remove('loading-location');
                    }
                },
                (error) => {
                    console.error('Location error:', error);
                    document.getElementById('locationText').textContent = 'Lokasi tidak dapat diakses';
                    document.getElementById('locationText').style.color = '#991b1b';
                }
            );
        } else {
            document.getElementById('locationText').textContent = 'Browser tidak mendukung geolocation';
        }

        // Update date/time
        function updateDateTime() {
            const now = new Date();
            const hari = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
            const hariNama = hari[now.getDay()];
            const tanggal = now.toLocaleDateString('id-ID', {
                day: '2-digit',
                month: 'long',
                year: 'numeric'
            });
            document.getElementById('dateTime').textContent = `${hariNama}, ${tanggal}`;
        }
        updateDateTime();

        // Live clock for Waktu Pulang
        let clockInterval = null;
        let clockStopped = false;

        function startLiveClock() {
            clockStopped = false;
            updateClockTime();
            clockInterval = setInterval(() => {
                if (!clockStopped) {
                    updateClockTime();
                }
            }, 1000);
        }

        function updateClockTime() {
            const now = new Date();
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');
            const seconds = String(now.getSeconds()).padStart(2, '0');
            const timeString = `${hours}:${minutes}:${seconds}`;
            document.getElementById('waktuPulang').value = timeString;
        }

        // Start live clock immediately
        startLiveClock();

        // Record clock-out time and submit
        async function recordClockOut() {
            // Stop the live clock
            clockStopped = true;

            // Disable button
            const btn = document.getElementById('btnAbsenPulang');
            btn.disabled = true;
            btn.textContent = 'Mengirim...';

            try {
                const waktuPulang = document.getElementById('waktuPulang').value;

                const response = await fetch('/pemagang/absen/clock-out', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        waktuPulang: waktuPulang
                    })
                });

                const data = await response.json();

                if (data.success) {
                    showToast(data.message, 'success');
                    window.location.href = '/pemagang/absen';
                } else {
                    showToast(data.message, 'warning');
                    btn.disabled = false;
                    btn.textContent = 'Absen Pulang';
                    // Restart clock
                    clockStopped = false;
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Terjadi kesalahan koneksi', 'error');
                btn.disabled = false;
                btn.textContent = 'Absen Pulang';
                // Restart clock
                clockStopped = false;
            }
        }

        // User menu dropdown toggle for mobile
        const userMenu = document.querySelector('.user-menu');
        if (userMenu) {
            userMenu.addEventListener('click', function (e) {
                if (window.innerWidth <= 768) {
                    this.classList.toggle('active');
                }
            });
        }
    </script>
</body>

<%- include('../../partials/logout-modal') %>
    <%- include('../../partials/toast-notification') %>

</html>