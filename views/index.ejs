<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Program Magang Infranexia - PT Telkom Infrastruktur Indonesia. Daftar dan kembangkan karirmu bersama kami.">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', 'Segoe UI', sans-serif;
        }
    </style>
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar" id="navbar">
        <div class="navbar-logo">
            <a href="/">
                <img src="/img/logotelkom.png" alt="Infranexia Logo">
            </a>
        </div>
        <div class="navbar-menu">
            <a href="#home" class="nav-link active">Home</a>
            <a href="#our-program" class="nav-link">Program</a>
            <a href="#persyaratan" class="nav-link">Persyaratan</a>
            <a href="/pendaftaran"
                class="<%= typeof currentPage !== 'undefined' && currentPage === 'pendaftaran' ? 'active' : '' %>">Pendaftaran</a>
            <a href="/faq"
                class="<%= typeof currentPage !== 'undefined' && currentPage === 'faq' ? 'active' : '' %>">FAQ</a>
        </div>
        <% if (locals.isAuthenticated) { %>
            <div class="user-menu">
                <div class="user-menu-trigger">
                    <div class="user-name-pill">
                        <span>Halo, <%= user.nama_depan %></span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
                            stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                    <img src="<%= user.foto_profil ? user.foto_profil : 'https://ui-avatars.com/api/?name=' + user.nama_depan + '+' + (user.nama_belakang || '') + '&size=40&background=E31937&color=fff&bold=true' %>"
                        alt="Profile" class="user-avatar">
                </div>
                <div class="dropdown-menu">
                    <a href="/profil" class="dropdown-item">Profil Saya</a>
                    <% if (locals.pendaftaranStatus === 'diterima') { %>
                        <div class="dropdown-divider"></div>
                        <a href="/pemagang/absen" class="dropdown-item">Absensi</a>
                        <a href="/pemagang/logbook" class="dropdown-item">Logbook</a>
                    <% } %>
                            <div class="dropdown-divider"></div>
                            <a href="/auth/logout" class="dropdown-item logout">Logout</a>
                </div>
            </div>
            <% } else { %>
                <a href="/auth/login?mode=register" class="btn-daftar">Daftar</a>
                <% } %>
                    <div class="mobile-menu-toggle" id="mobileMenuToggle">
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section" id="home">
        <div class="hero-content">
            <h1 class="hero-title">Mulai Langkah Kariermu Bersama Infranexia</h1>
            <p class="hero-subtitle">
                Daftar dan ikuti program magang Infranexia untuk mengembangkan keterampilan, memahami
                dunia kerja, dan mendapatkan pengalaman langsung di lingkungan profesional.
            </p>
        </div>

        <!-- Feature Cards -->
        <div class="feature-cards">
            <div class="feature-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path
                            d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                    <span>Quality</span>
                </div>
                <p class="feature-description">
                    Program magang terstruktur dan relevan dengan kebutuhan industri.
                </p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <span>Professional Working Environment</span>
                </div>
                <p class="feature-description">
                    Belajar dan berkembang di lingkungan kerja yang profesional.
                </p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <span>Experience</span>
                </div>
                <p class="feature-description">
                    Terlibat langsung dalam aktivitas dan proyek kerja.
                </p>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section class="about-section">
        <div class="about-container">
            <div class="about-left">
                <div class="about-logo">
                    <img src="/img/logotelkom.png" alt="Infranexia by Telkom Indonesia">
                </div>
                <div class="about-images">
                    <img src="/img/dashboard1.webp" alt="Dashboard Preview 1" class="about-img staggered-1">
                    <img src="/img/dashboard2.webp" alt="Dashboard Preview 2" class="about-img staggered-2">
                </div>
            </div>
            <div class="about-right">
                <h2>Tentang Infranexia</h2>
                <p>
                    PT Telkom Infrastruktur Indonesia (Perseroan) atau Infranexia adalah Perseroan
                    Terbatas yang bergerak di bidang penyediaan infrastruktur dan jasa jaringan
                    telekomunikasi, yang didirikan pada tanggal 8 Desember 2023.
                </p>
                <p>
                    Infranexia menyediakan layanan berbagai infrastruktur telekomunikasi untuk
                    Penyedia Layanan Internet (ISP) dan Operator Berlisensi Lainnya (OLO) serta
                    membantu mereka membangun bisnis mereka.
                </p>
                <a href="https://infraco.telkom.co.id/en/about-us" target="_blank" class="btn-view-more">
                    View More
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z" />
                    </svg>
                </a>
            </div>
        </div>
    </section>

    <!-- Our Program Section -->
    <section class="programs-section" id="our-program">
        <div class="container">
            <h2 class="section-title-white">OUR PROGRAM</h2>
            <div class="programs-grid">
                <div class="program-card">
                    <div class="program-content">
                        <h3>AOM</h3>
                        <p>Account Operation Manager - Mengelola operasional akun pelanggan korporasi dan memastikan
                            kualitas layanan infrastruktur tetap prima.</p>
                    </div>
                </div>
                <div class="program-card">
                    <div class="program-content">
                        <h3>ASO</h3>
                        <p>Access Support Operation - Menangani dukungan teknis operasional akses jaringan dan
                            pemeliharaan infrastruktur di lapangan.</p>
                    </div>
                </div>
                <div class="program-card">
                    <div class="program-content">
                        <h3>NOC</h3>
                        <p>Network Operation Center - Memonitor dan mengelola performa jaringan secara real-time
                            untuk
                            menjamin ketersediaan layanan 24/7.</p>
                    </div>
                </div>
            </div>
            <div class="section-footer">
                <a href="/program" class="see-detail">see detail</a>
            </div>
        </div>
    </section>

    <!-- Persyaratan Section -->
    <section class="requirements-section" id="persyaratan">
        <div class="container">
            <div class="requirements-header">
                <h2>PERSYARATAN</h2>
                <div class="red-line"></div>
            </div>
            <ul class="requirements-list">
                <li>
                    <span class="bullet"></span>
                    <p>Mahasiswa/i aktif D4/S1 minimal semester 5, atau fresh graduate maksimal 1 tahun setelah
                        kelulusan sesuai dengan kebutuhan perusahaan.</p>
                </li>
                <li>
                    <span class="bullet"></span>
                    <p>Berkomitmen kerja penuh waktu (Senin-Jumat) sesuai durasi yang telah ditentukan.</p>
                </li>
                <li>
                    <span class="bullet"></span>
                    <p>Memiliki kemampuan komunikasi yang baik serta dapat bekerja secara mandiri maupun dalam tim.
                    </p>
                </li>
            </ul>
        </div>
    </section>

    <style>
        /* Our Program Styles */
        .programs-section {
            background: linear-gradient(135deg, #E31937 0%, #b8152d 100%);
            padding: 80px 0;
            text-align: center;
            color: #fff;
        }

        .section-title-white {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 50px;
            letter-spacing: 2px;
        }

        .programs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-bottom: 40px;
        }

        .program-card {
            background: #fff;
            color: #333;
            padding: 40px 30px;
            border-radius: 12px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-align: left;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
            position: relative;
            overflow: hidden;
        }

        .program-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: #E31937;
            transform: scaleX(0);
            transition: transform 0.4s ease;
            transform-origin: left;
        }

        .program-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
        }

        .program-card:hover::after {
            transform: scaleX(1);
        }

        .program-card h3 {
            font-size: 22px;
            font-weight: 700;
            color: #E31937;
            margin-bottom: 20px;
        }

        .program-card p {
            font-size: 15px;
            line-height: 1.7;
            color: #666;
        }

        .see-detail {
            color: #fff;
            text-decoration: none;
            font-size: 18px;
            font-weight: 500;
            opacity: 0.9;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .see-detail::after {
            content: '→';
            transition: transform 0.3s ease;
        }

        .see-detail:hover {
            opacity: 1;
            letter-spacing: 1px;
        }

        .see-detail:hover::after {
            transform: translateX(5px);
        }

        /* Persyaratan Styles */
        .requirements-section {
            padding: 100px 0;
            background: #fff;
        }

        .requirements-header {
            text-align: center;
            margin-bottom: 50px;
        }

        .requirements-header h2 {
            font-size: 32px;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 10px;
            letter-spacing: 1px;
        }

        .red-line {
            width: 80px;
            height: 4px;
            background: #E31937;
            margin: 0 auto;
            border-radius: 2px;
        }

        .requirements-list {
            list-style: none;
            max-width: 800px;
            margin: 0 auto;
            padding: 0;
        }

        .requirements-list li {
            display: flex;
            align-items: flex-start;
            gap: 20px;
            margin-bottom: 25px;
            padding: 20px;
            background: #fdfdfd;
            border-radius: 10px;
            border-left: 3px solid #eee;
            transition: all 0.3s ease;
        }

        .requirements-list li:hover {
            background: #fff;
            border-left-color: #E31937;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            transform: translateX(5px);
        }

        .bullet {
            width: 12px;
            height: 12px;
            background: #E31937;
            border-radius: 50%;
            margin-top: 6px;
            flex-shrink: 0;
        }

        .requirements-list p {
            font-size: 16px;
            line-height: 1.6;
            color: #444;
            margin: 0;
        }

        @media (max-width: 768px) {
            .programs-grid {
                grid-template-columns: 1fr;
            }

            .requirements-list {
                padding: 0 20px;
            }
        }
    </style>

    <!-- Footer Divider -->
    <div class="footer-divider"></div>

    <!-- Footer -->
    <footer class="footer">
        <p>&copy; 2024 Infranexia - PT Telkom Infrastruktur Indonesia. All Rights Reserved.</p>
    </footer>

    <script>
        // Navbar scroll effect
        window.addEventListener('scroll', function () {
            const navbar = document.getElementById('navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        });

        // Mobile menu toggle
        const mobileMenuToggle = document.getElementById('mobileMenuToggle');
        const navbarMenu = document.querySelector('.navbar-menu');

        if (mobileMenuToggle) {
            mobileMenuToggle.addEventListener('click', function () {
                navbarMenu.classList.toggle('active');
            });
        }

        // Scroll Spy Logic
        const sections = document.querySelectorAll('section[id]');
        const navLinks = document.querySelectorAll('.navbar-menu a.nav-link');

        window.addEventListener('scroll', () => {
            let current = '';
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                const sectionHeight = section.clientHeight;
                if (pageYOffset >= (sectionTop - 200)) {
                    current = section.getAttribute('id');
                }
            });

            navLinks.forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href').includes(current)) {
                    link.classList.add('active');
                }
            });
        });

        // Sticky Navbar logic
        const navbar = document.getElementById('navbar');
        window.onscroll = () => {
            if (window.scrollY > 20) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        };

        // User menu dropdown toggle for mobile
        const userMenu = document.querySelector('.user-menu');
        if (userMenu) {
            userMenu.addEventListener('click', function (e) {
                if (window.innerWidth <= 768) {
                    this.classList.toggle('active');
                }
            });
        }
    </script>
</body>

<%- include('partials/logout-modal') %>
    <%- include('partials/toast-notification') %>

</html>